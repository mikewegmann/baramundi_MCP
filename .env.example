# Vorlage — kopiere diese Datei nach .env und trage deine Werte ein
# Die .env-Datei wird NICHT in Git eingecheckt!

BARAMUNDI_API_URL=https://dein-bmc-server/bconnect
BARAMUNDI_API_TOKEN=dein-x-api-key
BARAMUNDI_SSL_VERIFY=false

# macmon Network Access Control
MACMON_API_URL=https://dein-macmon-server
MACMON_USER=dein-benutzername
MACMON_PASSWORD=dein-passwort
MACMON_SSL_VERIFY=false

# Active Directory
AD_SERVER=ldap://dc01.schmitz.intern
AD_BIND_DN=CN=svc_mcp,OU=Servicekonten,DC=schmitz,DC=intern
AD_BIND_PASSWORD=dein-passwort
AD_BASE_DN=DC=schmitz,DC=intern
